{
  "name": "interactive-gear-simulator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "prepare": "git config core.hooksPath .githooks",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest --run",
    "test:unit": "vitest --run",
    "test:e2e": "playwright test --project=chromium --project=firefox-smoke --project=webkit-smoke",
    "test:integration": "eval $(supabase status -o env) && VITE_SUPABASE_URL=$API_URL VITE_SUPABASE_PUBLISHABLE_KEY=$ANON_KEY pnpm build && playwright test --project=supabase-integration",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "verify": "pnpm typecheck && pnpm lint && pnpm format && pnpm test:unit && VITE_SUPABASE_URL= VITE_SUPABASE_PUBLISHABLE_KEY= pnpm build && pnpm test:e2e",
    "verify:full": "pnpm verify && pnpm supabase:reset && pnpm supabase:test:db && pnpm supabase:types:check && pnpm test:integration",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:test:db": "supabase test db",
    "supabase:types": "supabase gen types typescript --local > src/lib/database.types.ts",
    "supabase:types:check": "supabase gen types typescript --local | diff src/lib/database.types.ts -"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "lucide-react": "^1.23.0",
    "pixi.js": "^8.19.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "supabase": "^2.109.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
